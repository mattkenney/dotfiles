#!/usr/bin/env python3
"""Convert epoch timestamps (seconds or milliseconds) to human-readable dates."""

import sys
from datetime import datetime, timezone

def parse_epoch(value):
    ts = int(value)
    if ts > 1e12:
        ts = ts / 1000
    utc = datetime.fromtimestamp(ts, tz=timezone.utc)
    local = datetime.fromtimestamp(ts).astimezone()
    return utc, local

def main():
    if len(sys.argv) < 2:
        print(f"Usage: {sys.argv[0]} <epoch> [epoch ...]", file=sys.stderr)
        sys.exit(1)

    rows = []
    for arg in sys.argv[1:]:
        utc, local = parse_epoch(arg)
        rows.append((arg, utc.isoformat(), local.isoformat()))

    widths = [max(len(r[i]) for r in rows) for i in range(3)]
    header = f"{'Epoch':<{widths[0]}}  {'UTC':<{widths[1]}}  {'Local':<{widths[2]}}"
    print(header)
    print("-" * len(header))
    for r in rows:
        print(f"{r[0]:<{widths[0]}}  {r[1]:<{widths[1]}}  {r[2]:<{widths[2]}}")

if __name__ == "__main__":
    main()
