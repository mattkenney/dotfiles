#!/bin/sh
set -e

BASE="${1:-code}"
i=1
IFS=$(printf '\n\b')
set -- $(find "${HOME}/${BASE}" -maxdepth 1 -mindepth 1 -type d | sort)
for dir; do
  name=$(basename "${dir}")
  printf '%2d: %s\n' "${i}" "${name}" >&2
  i=$((i + 1))
done
read -p "Type number and <Enter> (empty cancels): " n
case "$n" in
  [123456789]|[123456789][0123456789])
    eval "dir=\${${n}}"
    printf '%s' "${dir}"
    ;;

  *)
    printf .
    ;;
esac
