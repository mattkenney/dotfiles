#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["boto3"]
# ///
import glob
import os
import sys
import boto3

ec2 = boto3.resource("ec2")
client = boto3.client("ec2")


def get_name(instance):
    if instance.tags:
        for tag in instance.tags:
            if tag["Key"] == "Name":
                return tag["Value"]
    return ""


def find_by_name(name):
    return list(
        ec2.instances.filter(
            Filters=[{"Name": "tag:Name", "Values": [name]}]
        )
    )


def list_instances():
    instances = list(ec2.instances.all())
    if not instances:
        print("No instances found.")
        return
    rows = []
    for i in instances:
        rows.append((i.id, get_name(i), i.state["Name"], i.public_ip_address or ""))
    rows.sort(key=lambda r: r[1])
    id_w = max(len(r[0]) for r in rows)
    name_w = max(len(r[1]) for r in rows)
    name_w = max(name_w, 4)
    status_w = max(len(r[2]) for r in rows)
    status_w = max(status_w, 6)
    print(f"{'INSTANCE ID':<{id_w}}  {'NAME':<{name_w}}  {'STATUS':<{status_w}}  PUBLIC IP")
    for iid, name, status, ip in rows:
        print(f"{iid:<{id_w}}  {name:<{name_w}}  {status:<{status_w}}  {ip}")


def start_instances(name):
    instances = find_by_name(name)
    if not instances:
        print(f"No instances found with name '{name}'.")
        sys.exit(1)
    ids = [i.id for i in instances]
    client.start_instances(InstanceIds=ids)
    print(f"Starting {len(ids)} instance(s): {', '.join(ids)}...", flush=True)
    waiter = client.get_waiter("instance_running")
    waiter.wait(InstanceIds=ids)
    print("Running.")


def stop_instances(name):
    instances = find_by_name(name)
    if not instances:
        print(f"No instances found with name '{name}'.")
        sys.exit(1)
    ids = [i.id for i in instances]
    client.stop_instances(InstanceIds=ids)
    print(f"Stopping {len(ids)} instance(s): {', '.join(ids)}...", flush=True)
    waiter = client.get_waiter("instance_stopped")
    waiter.wait(InstanceIds=ids)
    print("Stopped.")


def print_ip(name):
    instances = find_by_name(name)
    if not instances:
        print(f"No instances found with name '{name}'.")
        sys.exit(1)
    ip = instances[0].public_ip_address
    if ip:
        print(ip)
    else:
        print(f"No public IP for '{name}'.")
        sys.exit(1)


def ssh_instance(name):
    instances = find_by_name(name)
    if not instances:
        print(f"No instances found with name '{name}'.")
        sys.exit(1)
    ip = instances[0].public_ip_address
    if not ip:
        print(f"No public IP for '{name}'.")
        sys.exit(1)
    pem_files = sorted(glob.glob(os.path.expanduser("~/.ssh/*.pem")))
    cmd = ["ssh"]
    for pem in pem_files:
        cmd += ["-i", pem]
    cmd += ["-o", "StrictHostKeyChecking=no", "-o", "UserKnownHostsFile=/dev/null", f"ubuntu@{ip}"]
    os.execvp("ssh", cmd)


def usage():
    print("Usage:")
    print("  cs              List all EC2 instances")
    print("  cs start NAME   Start instance(s) with name")
    print("  cs stop NAME    Stop instance(s) with name")
    print("  cs ip NAME      Print public IP of instance")
    print("  cs ssh NAME     SSH into instance")
    sys.exit(1)


def main():
    args = sys.argv[1:]
    if not args:
        list_instances()
    elif args[0] == "start" and len(args) == 2:
        start_instances(args[1])
    elif args[0] == "stop" and len(args) == 2:
        stop_instances(args[1])
    elif args[0] == "ip" and len(args) == 2:
        print_ip(args[1])
    elif args[0] == "ssh" and len(args) == 2:
        ssh_instance(args[1])
    else:
        usage()


if __name__ == "__main__":
    main()
